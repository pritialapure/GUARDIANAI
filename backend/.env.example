# ============================================================
# Guardian Council AI — Backend Environment Variables
# Copy this file to `.env` in the backend/ directory and fill
# in real values. Never commit your actual .env file.
# ============================================================

# --- Application ---
APP_NAME=Guardian Council AI
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO

# --- CORS (comma separated origins allowed to call the API) ---
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# --- Google Gemini ---
GOOGLE_API_KEY=your_google_gemini_api_key_here
GEMINI_CHAT_MODEL=gemini-2.5-flash
GEMINI_EMBEDDING_MODEL=models/gemini-embedding-001

# --- Embeddings provider ---
# "gemini" uses Google embeddings. "huggingface" is a local fallback
# if Gemini embeddings hit compatibility/quota issues.
EMBEDDING_PROVIDER=gemini
HUGGINGFACE_EMBEDDING_MODEL=sentence-transformers/all-mpnet-base-v2

# --- Vector store (ChromaDB) ---
CHROMA_PERSIST_DIR=./chroma_db
CHROMA_COLLECTION_NAME=guardian_council_knowledge_base
KNOWLEDGE_BASE_DIR=./knowledge_base

# --- Chunking ---
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
RETRIEVAL_TOP_K=4

# Free-tier Gemini embedding quota is commonly 100 requests/minute.
# Ingestion batches chunks and pauses between batches to stay under it.
# Lower EMBEDDING_BATCH_SIZE / raise the delay if you still hit 429 errors.
EMBEDDING_BATCH_SIZE=90
EMBEDDING_BATCH_DELAY_SECONDS=61

# --- Tavily (optional, used by the Tool Agent for live web search) ---
TAVILY_API_KEY=your_tavily_api_key_here

# --- MCP tool placeholders (safe to leave blank in dev; tools degrade gracefully) ---
WEATHER_API_KEY=
MAPS_API_KEY=
HOSPITAL_FINDER_API_KEY=

# --- Memory backend ---
MEMORY_BACKEND=in_memory
SQLITE_MEMORY_PATH=./memory_store.sqlite
